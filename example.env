SERVER_PORT=3000
NODE_ENV=development

MONGO_DB_URL=mongodb://localhost:27017/tupuntoDB

CLIENT_URL=http://localhost:5173
CLIENT_URL_2=http://localhost:5174

# Use at least 32 random characters in production.
JWT_SECRET=change-me-with-a-long-random-secret
SESSION_TTL_HOURS=24
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Internal integrations
CATALOG_INTEGRATION_TOKEN=change-me-with-a-long-random-token

# AWS / S3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# QZ Tray signing. Prefer *_BASE64 for multiline PEM values.
QZ_CERT_PEM_BASE64=
QZ_PRIVATE_KEY_PEM_BASE64=

# Google Drive service account
TYPE=service_account
PROJECT_ID=
PRIVATE_KEY_ID=
PRIVATE_KEY=
CLIENT_EMAIL=
CLIENT_ID=
AUTH_URI=https://accounts.google.com/o/oauth2/auth
TOKEN_URI=https://oauth2.googleapis.com/token
AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
CLIENT_X509_CERT_URL=
UNIVERSE_DOMAIN=googleapis.com

# WhatsApp
W_PHONE_NUMBER_ID=
W_RECIPIENT_PHONE=
W_VERSION=v20.0
W_GUIDE_TEMPLATE_LANGUAGE=es
W_BUYER_SAME_BRANCH_TEMPLATE_NAME=
W_BUYER_TRANSFER_TEMPLATE_NAME=
W_SELLER_PACKAGES_TEMPLATE_NAME=
W_SEND_SELLER_GUIDE_MESSAGES=false
W_DEFAULT_BRANCH_LOCATION_BUTTON_VALUE=
W_BEARER_TOKEN=
